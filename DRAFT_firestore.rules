rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isGuru() {
      return hasRole('guru');
    }

    function isTEN() {
      return hasRole('tenaga_kependidikan');
    }

    function isSiswa() {
      return hasRole('siswa');
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Users ---
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isAdmin() || request.auth.uid == uid);
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid == uid);
      allow delete: if isAdmin();
    }

    // --- Students ---
    match /students/{nisn} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGuru();
    }

    // --- Attendance ---
    match /attendance/{id} {
      allow read: if isAdmin() || isGuru() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && (
        (request.resource.data.type == 'employee' && request.resource.data.userId == request.auth.uid) ||
        (request.resource.data.type == 'student' && (isAdmin() || isGuru()))
      );
      allow list: if isAdmin() || isGuru() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // --- Exams ---
    match /exams/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isGuru();
    }

    // --- Exam Results ---
    match /exam_results/{id} {
      allow read: if isAdmin() || isGuru() || (isSignedIn() && resource.data.studentId == getUserData().nisn);
      allow create: if isSignedIn() && isSiswa();
      allow list: if isAdmin() || isGuru() || (isSignedIn() && resource.data.studentId == getUserData().nisn);
    }
  }
}
